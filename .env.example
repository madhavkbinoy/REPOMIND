# Get your free Groq key: https://console.groq.com
# Get your GitHub token with repo:read scope from GitHub Settings > Developer settings
GROQ_API_KEY=your_groq_api_key_here
GITHUB_TOKEN=your_github_token_here

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis for Celery
REDIS_URL=redis://localhost:6379/0

# SQLite database
DATABASE_PATH=./db/repomind.db

# Confidence threshold for LLM generation
CONFIDENCE_THRESHOLD=0.40
MAX_CHUNK_TOKENS=500

# Subset control — scoped to kubelet subsystem
# For first run: 50 is quick (15-30 min), 200 gives more data (1-3 hours)
MAX_ISSUES=500
MAX_PRS=50
KUBELET_ISSUE_LABELS=area/kubelet,component/kubelet
KUBELET_FILE_PREFIX=pkg/kubelet